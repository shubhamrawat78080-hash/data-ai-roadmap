// ══════════════════════════════════════════════════════
// STATE
// ══════════════════════════════════════════════════════
function loadState(){
  try{ return JSON.parse(localStorage.getItem('roadmap_state')||'{}'); }catch(e){return{};}
}
function saveState(state){
  localStorage.setItem('roadmap_state', JSON.stringify(state));
}

let state = loadState();

// Ensure defaults
roadmap.forEach(ph=>ph.weeks.forEach(wk=>{
  wk.days.forEach(d=>d.tasks.forEach(t=>{
    if(state[t.id]===undefined) state[t.id]=false;
  }));
  if(state['summary_'+wk.id]===undefined) state['summary_'+wk.id]='';
}));

// ══════════════════════════════════════════════════════
// RENDER
// ══════════════════════════════════════════════════════
function allTasksInWeekDone(wk){
  return wk.days.every(d=>d.tasks.every(t=>state[t.id]===true));
}
function weekProgress(wk){
  const all=wk.days.flatMap(d=>d.tasks);
  const done=all.filter(t=>state[t.id]).length;
  return{done,total:all.length,pct:all.length?Math.round(done/all.length*100):0};
}
function totalProgress(){
  const all=roadmap.flatMap(ph=>ph.weeks.flatMap(wk=>wk.days.flatMap(d=>d.tasks)));
  const done=all.filter(t=>state[t.id]).length;
  const summaries=roadmap.flatMap(ph=>ph.weeks.map(wk=>state['summary_'+wk.id]||''));
  const sdone=summaries.filter(s=>s.trim().length>20).length;
  return{tasks:{done,total:all.length},summaries:{done:sdone,total:summaries.length}};
}

function renderAll(){
  renderPhases();
  renderSidebar();
  updateOverallProgress();
}

function renderPhases(){
  const container=document.getElementById('phases-container');
  container.innerHTML='';
  roadmap.forEach((ph,pi)=>{
    const sec=document.createElement('div');
    sec.className=`phase-section ${ph.cls}`;
    sec.id=ph.id;
    sec.style.animationDelay=`${0.1+pi*0.1}s`;

    // phase header
    sec.innerHTML=`
      <div class="phase-header">
        <div class="ph-icon">${ph.icon}</div>
        <div>
          <div class="ph-title">${ph.name}</div>
          <div class="ph-sub">${ph.sub}</div>
        </div>
        <div class="ph-weeks-badge">${ph.label} · Weeks ${ph.weeks[0].id.replace('w','')}–${ph.weeks[ph.weeks.length-1].id.replace('w','')}</div>
      </div>
    `;

    ph.weeks.forEach(wk=>{
      sec.appendChild(renderWeek(wk, ph.cls));
    });
    container.appendChild(sec);
  });
}

function renderWeek(wk, phCls){
  const {done,total,pct}=weekProgress(wk);
  const isOpen=true;
  const allDone=allTasksInWeekDone(wk);
  const hasSummary=(state['summary_'+wk.id]||'').trim().length>20;

  const div=document.createElement('div');
  div.className=`week-block ${phCls} ${isOpen?'open':''}`;
  div.id='wk-'+wk.id;

  div.innerHTML=`
    <div class="week-header" onclick="toggleWeek('${wk.id}')">
      <div class="wh-badge">${wk.label}</div>
      <div class="wh-title">${wk.title}</div>
      <div class="wh-progress">
        <div class="wh-prog-bar"><div class="wh-prog-fill" style="width:${pct}%"></div></div>
        <div class="wh-pct">${pct}%</div>
      </div>
      <div class="wh-chevron">▶</div>
    </div>
    <div class="week-body">
      ${wk.days.map(d=>renderDay(d, phCls)).join('')}
      ${renderSummary(wk, phCls, allDone, hasSummary)}
    </div>
  `;
  return div;
}

function renderDay(d, phCls){
  return `
    <div class="day-section">
      <div class="day-label" style="color:${d.color}">${d.label}</div>
      ${d.tasks.map(t=>renderTask(t, phCls)).join('')}
    </div>
  `;
}

function renderTask(t, phCls){
  const checked=state[t.id];
  return `
    <div class="task-item ${checked?'checked':''}" onclick="toggleTask('${t.id}')">
      <div class="task-cb"><span class="task-cb-check">✓</span></div>
      <div class="task-text">${t.text}</div>
    </div>
  `;
}

function renderSummary(wk, phCls, allDone, hasSummary){
  const val=state['summary_'+wk.id]||'';
  const unlocked=allDone;
  return `
    <div class="summary-section ${unlocked?'summary-unlocked':''}" id="sum-${wk.id}">
      <div class="summary-header">
        <span class="summary-lock">${unlocked?'📝':'🔒'}</span>
        <span>WEEK SUMMARY</span>
        <span class="summary-required">${hasSummary?'✓ SAVED':'REQUIRED'}</span>
      </div>
      <div class="summary-body">
        <div class="summary-locked-msg">
          <span>🔒</span>
          <span>Complete all ${wk.days.reduce((a,d)=>a+d.tasks.length,0)} tasks above to unlock your weekly summary. The summary is <strong>mandatory</strong> — it consolidates your learning.</span>
        </div>
        <div class="summary-textarea-wrap">
          <div class="summary-prompt">
            <strong>Reflection prompt:</strong> ${wk.summaryPrompt}
          </div>
          <textarea class="summary-input"
            id="textarea-${wk.id}"
            placeholder="Write your summary here (minimum 20 characters to save)…"
            oninput="onSummaryInput('${wk.id}')"
          >${val}</textarea>

```
      <button class="summary-save-btn"
        id="savebtn-${wk.id}"
        onclick="saveSummary('${wk.id}')"
        ${val.trim().length>20?'':'disabled'}
      >Save Summary</button>
      <div class="summary-saved-note ${hasSummary?'show':''}" id="saved-note-${wk.id}">✓ Summary saved</div>
    </div>
  </div>
</div>
```

`;
}

// ══════════════════════════════════════════════════════
// INTERACTIONS
// ══════════════════════════════════════════════════════
function toggleTask(id){
state[id]=!state[id];
saveState(state);
// Find which week this task belongs to
const wk=roadmap.flatMap(ph=>ph.weeks).find(w=>w.days.some(d=>d.tasks.some(t=>t.id===id)));
if(!wk) return;
refreshWeek(wk);
updateOverallProgress();
renderSidebarNav();
}

function toggleWeek(wkId){
const el=document.getElementById(‘wk-’+wkId);
if(!el) return;
if(el.classList.contains(‘closed’)){
el.classList.remove(‘closed’);
el.classList.add(‘open’);
} else {
el.classList.add(‘closed’);
el.classList.remove(‘open’);
}
}

function onSummaryInput(wkId){
const ta=document.getElementById(‘textarea-’+wkId);
const btn=document.getElementById(‘savebtn-’+wkId);
if(ta && btn) btn.disabled=ta.value.trim().length<=20;
}

function saveSummary(wkId){
const ta=document.getElementById(‘textarea-’+wkId);
if(!ta) return;
state[‘summary_’+wkId]=ta.value;
saveState(state);
const note=document.getElementById(‘saved-note-’+wkId);
if(note){ note.classList.add(‘show’); }
const req=document.querySelector(`#sum-${wkId} .summary-required`);
if(req){ req.textContent=‘✓ SAVED’; }
updateOverallProgress();
renderSidebarNav();
}

function refreshWeek(wk){
const el=document.getElementById(‘wk-’+wk.id);
if(!el) return;
const phCls=roadmap.find(ph=>ph.weeks.includes(wk))?.cls||’’;
const isOpen=el.classList.contains(‘open’);
const {pct}=weekProgress(wk);
const allDone=allTasksInWeekDone(wk);
const hasSummary=(state[‘summary_’+wk.id]||’’).trim().length>20;

// update progress bar
const fill=el.querySelector(’.wh-prog-fill’);
const pctEl=el.querySelector(’.wh-pct’);
if(fill) fill.style.width=pct+’%’;
if(pctEl) pctEl.textContent=pct+’%’;

// update individual task states
wk.days.forEach(d=>d.tasks.forEach(t=>{
const items=el.querySelectorAll(’.task-item’);
items.forEach(item=>{
const onclick=item.getAttribute(‘onclick’)||’’;
if(onclick.includes(`'${t.id}'`)){
if(state[t.id]) item.classList.add(‘checked’);
else item.classList.remove(‘checked’);
}
});
}));

// update summary unlock state
const sumEl=document.getElementById(‘sum-’+wk.id);
if(sumEl){
if(allDone){
sumEl.classList.add(‘summary-unlocked’);
const lock=sumEl.querySelector(’.summary-lock’);
if(lock) lock.textContent=‘📝’;
}
const req=sumEl.querySelector(’.summary-required’);
if(req && hasSummary) req.textContent=‘✓ SAVED’;
}
}

// ══════════════════════════════════════════════════════
// SIDEBAR
// ══════════════════════════════════════════════════════
function renderSidebar(){
const nav=document.getElementById(‘sidebar-nav’);
nav.innerHTML=’’;
roadmap.forEach(ph=>{
const phDiv=document.createElement(‘div’);
phDiv.className=‘nav-phase’;
let html=`<div class="nav-phase-label">${ph.label} — ${ph.name}</div>`;
ph.weeks.forEach(wk=>{
const {pct,done,total}=weekProgress(wk);
const hasSummary=(state[‘summary_’+wk.id]||’’).trim().length>20;
const allDone=done===total&&hasSummary;
html+=`<a class="nav-week ${allDone?'done':''}" href="#wk-${wk.id}"> <div class="nw-dot"></div> <span>${wk.label}: ${wk.title.substring(0,22)}${wk.title.length>22?'…':''}</span> <span class="nw-pct">${pct}%</span> </a>`;
});
phDiv.innerHTML=html;
nav.appendChild(phDiv);
});
}
function renderSidebarNav(){ renderSidebar(); }

function updateOverallProgress(){
const all=roadmap.flatMap(ph=>ph.weeks.flatMap(wk=>wk.days.flatMap(d=>d.tasks)));
const done=all.filter(t=>state[t.id]).length;
const total=all.length;
const pct=Math.round(done/total*100);

const bar=document.getElementById(‘overall-bar’);
const pctEl=document.getElementById(‘overall-pct’);
const countEl=document.getElementById(‘overall-count’);
if(bar) bar.style.width=pct+’%’;
if(pctEl) pctEl.textContent=pct+’%’;
if(countEl) countEl.textContent=`${done} / ${total} tasks`;

// check complete
const allSummaries=roadmap.flatMap(ph=>ph.weeks.map(wk=>(state[‘summary_’+wk.id]||’’).trim().length>20));
const allSumDone=allSummaries.every(Boolean);
const banner=document.getElementById(‘complete-banner’);
if(banner){
if(done===total && allSumDone) banner.classList.add(‘show’);
else banner.classList.remove(‘show’);
}
}

// ══════════════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════════════
renderAll();
</script>

</body>
</html>
